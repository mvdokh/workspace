#!/usr/bin/env bash

# workspace — launch and arrange apps from a JSON config
# Usage: workspace <name>
# Configs live in ~/.workspaces/<name>.json
# Dependencies: none (uses built-in osascript/JXA for JSON parsing + window management)

set -euo pipefail

WORKSPACES_DIR="$HOME/.workspaces"
LAUNCH_AGENTS_DIR="$HOME/Library/LaunchAgents"

# ── helpers ────────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
workspace — arrange apps on screen from a JSON config

Usage:
  workspace <name>                  Launch workspace by name
  workspace list                    List all saved workspaces
  workspace edit <name>             Open config in \$EDITOR (creates if missing)
  workspace schedule <name> <time>  Auto-launch daily, e.g. "9:00"
  workspace unschedule <name>       Remove a scheduled launch
  workspace schedules               List all scheduled workspaces
  workspace shortcuts               Print all registered shortcuts
  workspace help                    Show this message

Config files live in: ~/.workspaces/<name>.json

Example JSON:
  {
    "name": "work",
    "shortcut": "ctrl+shift+1",
    "scripts": ["cd ~/Desktop"],
    "apps": [
      { "app": "Slack",    "zone": "right-half", "monitor": 1 },
      { "app": "Safari",   "zone": "left-half",  "monitor": 1, "url": "https://en.wikipedia.org/wiki/Hippocrates" },
      { "app": "Terminal", "zone": "full",        "monitor": 2 }
    ]
  }

Available zones:
  full                   left-half          right-half
  top-half               bottom-half
  top-left-quarter       top-right-quarter
  bottom-left-quarter    bottom-right-quarter
  center-large           center-small
EOF
}

die()  { echo "❌  $*" >&2; exit 1; }
info() { echo "→  $*"; }

# ── read a single value from a JSON file via JXA ──────────────────────────────

json_get() {
  local file="$1"
  local expr="$2"   # JS expression evaluated against the parsed object, e.g. 'o.name'
  osascript -l JavaScript <<JSEOF
var o = JSON.parse($.NSString.stringWithContentsOfFileEncodingError('$file', $.NSUTF8StringEncoding, null).js);
var v = $expr;
v === undefined || v === null ? "" : String(v);
JSEOF
}

# ── run the entire launch sequence in one JXA pass ────────────────────────────
# Reads config, runs scripts, then launches + positions every app.

jxa_launch() {
  local config="$1"
  osascript -l JavaScript <<'JSEOF'
ObjC.import('Foundation');
ObjC.import('AppKit');

// ── helpers ──────────────────────────────────────────────────────────────────

function sleep(ms) {
  var date = new Date();
  while (new Date() - date < ms) {}
}

function zoneRect(zone, ox, oy, sw, sh) {
  var z = {
    'full':                  [0,    0,    1,    1   ],
    'left-half':             [0,    0,    0.5,  1   ],
    'right-half':            [0.5,  0,    0.5,  1   ],
    'top-half':              [0,    0,    1,    0.5 ],
    'bottom-half':           [0,    0.5,  1,    0.5 ],
    'top-left-quarter':      [0,    0,    0.5,  0.5 ],
    'top-right-quarter':     [0.5,  0,    0.5,  0.5 ],
    'bottom-left-quarter':   [0,    0.5,  0.5,  0.5 ],
    'bottom-right-quarter':  [0.5,  0.5,  0.5,  0.5 ],
    'center-large':          [0.1,  0.1,  0.8,  0.8 ],
    'center-small':          [0.2,  0.2,  0.6,  0.6 ],
  }[zone];
  if (!z) throw new Error("Unknown zone: " + zone);
  return {
    x: Math.round(ox + z[0] * sw),
    y: Math.round(oy + z[1] * sh),
    w: Math.round(z[2] * sw),
    h: Math.round(z[3] * sh),
  };
}

function monitorBounds(monitorIdx) {
  // monitorIdx is 0-based
  var screens = $.NSScreen.screens;
  var idx = monitorIdx < screens.count ? monitorIdx : 0;
  var primaryH = $.NSScreen.screens.objectAtIndex(0).frame.size.height;
  var frame = $.NSScreen.screens.objectAtIndex(idx).frame;
  return {
    ox: Math.round(frame.origin.x),
    oy: Math.round(primaryH - frame.origin.y - frame.size.height),
    sw: Math.round(frame.size.width),
    sh: Math.round(frame.size.height),
  };
}

function activateAndPosition(appName, zone, monitorIdx, url) {
  var app = Application(appName);
  app.includeStandardAdditions = true;

  if (url) {
    app.activate();
    app.openLocation(url);
  } else {
    app.activate();
  }

  // wait for app window to appear
  var waited = 0;
  while (waited < 3000) {
    sleep(200);
    waited += 200;
    try {
      if (Application('System Events').processes[appName].windows.length > 0) break;
    } catch(e) {}
  }

  var mb  = monitorBounds(monitorIdx);
  var r   = zoneRect(zone, mb.ox, mb.oy, mb.sw, mb.sh);
  var se  = Application('System Events');
  var proc = se.processes[appName];
  if (proc.windows.length > 0) {
    proc.windows[0].position = [r.x, r.y];
    proc.windows[0].size     = [r.w, r.h];
  }
}

// ── main ─────────────────────────────────────────────────────────────────────

var configPath = Application('bash').doShellScript('echo ' + $.NSProcessInfo.processInfo.environment.objectForKey('WS_CONFIG').js);
JSEOF

  # Re-invoke with config path injected via env
  WS_CONFIG="$config" osascript -l JavaScript <<JSEOF
ObjC.import('Foundation');
ObjC.import('AppKit');

function sleep(ms) {
  var start = new Date();
  while (new Date() - start < ms) {}
}

function zoneRect(zone, ox, oy, sw, sh) {
  var zones = {
    'full':                  [0,    0,    1,    1   ],
    'left-half':             [0,    0,    0.5,  1   ],
    'right-half':            [0.5,  0,    0.5,  1   ],
    'top-half':              [0,    0,    1,    0.5 ],
    'bottom-half':           [0,    0.5,  1,    0.5 ],
    'top-left-quarter':      [0,    0,    0.5,  0.5 ],
    'top-right-quarter':     [0.5,  0,    0.5,  0.5 ],
    'bottom-left-quarter':   [0,    0.5,  0.5,  0.5 ],
    'bottom-right-quarter':  [0.5,  0.5,  0.5,  0.5 ],
    'center-large':          [0.1,  0.1,  0.8,  0.8 ],
    'center-small':          [0.2,  0.2,  0.6,  0.6 ],
  };
  var z = zones[zone];
  if (!z) throw new Error('Unknown zone: ' + zone);
  return {
    x: Math.round(ox + z[0] * sw),
    y: Math.round(oy + z[1] * sh),
    w: Math.round(z[2] * sw),
    h: Math.round(z[3] * sh),
  };
}

function monitorBounds(monitorIdx) {
  var screens = $.NSScreen.screens;
  var idx = (monitorIdx < screens.count) ? monitorIdx : 0;
  var primaryH = $.NSScreen.screens.objectAtIndex(0).frame.size.height;
  var frame = $.NSScreen.screens.objectAtIndex(idx).frame;
  return {
    ox: Math.round(frame.origin.x),
    oy: Math.round(primaryH - frame.origin.y - frame.size.height),
    sw: Math.round(frame.size.width),
    sh: Math.round(frame.size.height),
  };
}

function waitForWindow(appName, timeoutMs) {
  var se = Application('System Events');
  var waited = 0;
  while (waited < timeoutMs) {
    sleep(200);
    waited += 200;
    try {
      if (se.processes.byName(appName).windows.length > 0) return true;
    } catch(e) {}
  }
  return false;
}

function positionApp(appName, zone, monitorIdx, url) {
  var app = Application(appName);
  if (url) {
    app.activate();
    app.openLocation(url);
  } else {
    app.activate();
  }

  waitForWindow(appName, 3000);

  var mb = monitorBounds(monitorIdx);
  var r  = zoneRect(zone, mb.ox, mb.oy, mb.sw, mb.sh);
  var se = Application('System Events');
  try {
    var wins = se.processes.byName(appName).windows;
    if (wins.length > 0) {
      wins[0].position = [r.x, r.y];
      wins[0].size     = [r.w, r.h];
    }
  } catch(e) {
    // window may not support positioning (e.g. fullscreen)
  }
}

// ── read config ───────────────────────────────────────────────────────────────

var configPath = $.NSProcessInfo.processInfo.environment.objectForKey('WS_CONFIG').js;
var raw = $.NSString.stringWithContentsOfFileEncodingError(configPath, $.NSUTF8StringEncoding, null).js;
var cfg = JSON.parse(raw);

// ── run scripts ───────────────────────────────────────────────────────────────

var scripts = cfg.scripts || [];
for (var s = 0; s < scripts.length; s++) {
  Application('Terminal'); // ensure shell is available
  var sh = Application('bash');
  sh.includeStandardAdditions = true;
  sh.doShellScript(scripts[s]);
}

// ── launch apps ───────────────────────────────────────────────────────────────

var apps = cfg.apps || [];
for (var i = 0; i < apps.length; i++) {
  var entry   = apps[i];
  var appName = entry.app;
  var zone    = entry.zone;
  var monitor = (entry.monitor || 1) - 1;  // convert to 0-based
  var url     = entry.url || '';
  positionApp(appName, zone, monitor, url);
}

cfg.name + ' launched (' + apps.length + ' apps)';
JSEOF
}

# ── subcommands ────────────────────────────────────────────────────────────────

cmd_list() {
  mkdir -p "$WORKSPACES_DIR"
  local files=("$WORKSPACES_DIR"/*.json)
  if [[ ! -e "${files[0]}" ]]; then
    echo "No workspaces yet. Create one with: workspace edit <name>"
    return
  fi
  echo "Saved workspaces:"
  for f in "${files[@]}"; do
    local name scheduled
    name=$(basename "$f" .json)
    scheduled=""
    local shortcut
    shortcut=$(osascript -l JavaScript <<JSEOF
ObjC.import('Foundation');
var raw = $.NSString.stringWithContentsOfFileEncodingError('$f', $.NSUTF8StringEncoding, null).js;
var o = JSON.parse(raw);
o.shortcut || '';
JSEOF
)
    local plist="$LAUNCH_AGENTS_DIR/com.workspace.$name.plist"
    [[ -f "$plist" ]] && scheduled=" [scheduled]"
    if [[ -n "$shortcut" ]]; then
      printf "  %-20s  (%s)%s\n" "$name" "$shortcut" "$scheduled"
    else
      printf "  %-20s%s\n" "$name" "$scheduled"
    fi
  done
}

cmd_edit() {
  local name="$1"
  mkdir -p "$WORKSPACES_DIR"
  local config="$WORKSPACES_DIR/$name.json"
  if [[ ! -f "$config" ]]; then
    cat > "$config" <<EOF
{
  "name": "$name",
  "shortcut": "ctrl+shift+1",
  "scripts": ["cd ~/Desktop"],
  "apps": [
    { "app": "Safari",   "zone": "left-half",  "monitor": 1, "url": "https://en.wikipedia.org/wiki/Hippocrates" },
    { "app": "Terminal", "zone": "right-half", "monitor": 1 }
  ]
}
EOF
    info "Created new config: $config"
  fi
  "${EDITOR:-nano}" "$config"
}

cmd_shortcuts() {
  mkdir -p "$WORKSPACES_DIR"
  local found=false
  for f in "$WORKSPACES_DIR"/*.json; do
    [[ -e "$f" ]] || continue
    local sc
    sc=$(osascript -l JavaScript <<JSEOF
ObjC.import('Foundation');
var raw = $.NSString.stringWithContentsOfFileEncodingError('$f', $.NSUTF8StringEncoding, null).js;
var o = JSON.parse(raw);
o.shortcut || '';
JSEOF
)
    if [[ -n "$sc" ]]; then
      printf "  %-15s  %s\n" "$(basename "$f" .json)" "$sc"
      found=true
    fi
  done
  $found || echo "No shortcuts registered in any workspace."
  echo ""
  echo "Note: shortcuts in the JSON are for reference — wire them up via"
  echo "Raycast, BetterTouchTool, or macOS Shortcuts to run: workspace <name>"
}

cmd_schedule() {
  local name="$1"
  local time="$2"
  local config="$WORKSPACES_DIR/$name.json"
  [[ -f "$config" ]] || die "No workspace named '$name'. File not found: $config"

  local hour minute
  hour=$(echo "$time"   | cut -d: -f1)
  minute=$(echo "$time" | cut -d: -f2)
  [[ "$hour"   =~ ^[0-9]+$ ]] || die "Invalid time format. Use HH:MM, e.g. 9:00"
  [[ "$minute" =~ ^[0-9]+$ ]] || die "Invalid time format. Use HH:MM, e.g. 9:00"

  mkdir -p "$LAUNCH_AGENTS_DIR"
  local plist="$LAUNCH_AGENTS_DIR/com.workspace.$name.plist"
  local workspace_bin
  workspace_bin=$(command -v workspace)

  cat > "$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.workspace.$name</string>
  <key>ProgramArguments</key>
  <array>
    <string>$workspace_bin</string>
    <string>$name</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>$hour</integer>
    <key>Minute</key>
    <integer>$minute</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>$HOME/.workspaces/$name.schedule.log</string>
  <key>StandardErrorPath</key>
  <string>$HOME/.workspaces/$name.schedule.log</string>
</dict>
</plist>
EOF

  launchctl unload "$plist" 2>/dev/null || true
  launchctl load "$plist"
  echo "✅  Scheduled '$name' to launch daily at $(printf '%02d:%02d' "$hour" "$minute")."
  echo "    Log: ~/.workspaces/$name.schedule.log"
}

cmd_unschedule() {
  local name="$1"
  local plist="$LAUNCH_AGENTS_DIR/com.workspace.$name.plist"
  [[ -f "$plist" ]] || die "No schedule found for '$name'."
  launchctl unload "$plist" 2>/dev/null || true
  rm "$plist"
  echo "✅  Removed schedule for '$name'."
}

cmd_schedules() {
  local found=false
  for plist in "$LAUNCH_AGENTS_DIR"/com.workspace.*.plist; do
    [[ -e "$plist" ]] || continue
    local name hour minute
    name=$(basename "$plist" .plist | sed 's/com\.workspace\.//')
    hour=$(grep -A1   '<key>Hour</key>'   "$plist" | grep integer | tr -dc '0-9')
    minute=$(grep -A1 '<key>Minute</key>' "$plist" | grep integer | tr -dc '0-9')
    printf "  %-20s  daily at %02d:%02d\n" "$name" "$hour" "$minute"
    found=true
  done
  $found || echo "No workspaces are scheduled."
}

cmd_launch() {
  local name="$1"
  local config="$WORKSPACES_DIR/$name.json"
  [[ -f "$config" ]] || die "No workspace named '$name'. File not found: $config"

  # Check accessibility permission
  osascript -e 'tell application "System Events" to get name of first process' &>/dev/null || {
    echo "⚠️  Accessibility access needed."
    echo "   Go to: System Settings → Privacy & Security → Accessibility"
    echo "   Add your terminal app (Terminal / iTerm2 / etc.)"
    exit 1
  }

  # Read name + app count for the status line (single JXA call)
  local ws_info
  ws_info=$(osascript -l JavaScript <<JSEOF
ObjC.import('Foundation');
var raw = $.NSString.stringWithContentsOfFileEncodingError('$config', $.NSUTF8StringEncoding, null).js;
var o = JSON.parse(raw);
o.name + '|' + (o.apps || []).length + '|' + (o.scripts || []).join('§');
JSEOF
)
  local ws_name total scripts_raw
  ws_name=$(echo "$ws_info"    | cut -d'|' -f1)
  total=$(echo "$ws_info"      | cut -d'|' -f2)
  scripts_raw=$(echo "$ws_info"| cut -d'|' -f3)

  echo "🚀  Launching workspace: $ws_name ($total apps)"

  # Run scripts
  if [[ -n "$scripts_raw" ]]; then
    info "Running scripts..."
    IFS='§' read -ra scripts <<< "$scripts_raw"
    for script in "${scripts[@]}"; do
      info "  $ $script"
      eval "$script" || echo "  ⚠️  Script exited non-zero: $script"
    done
  fi

  # Launch and position all apps in one JXA pass
  info "Positioning apps..."
  WS_CONFIG="$config" osascript -l JavaScript <<'JSEOF'
ObjC.import('Foundation');
ObjC.import('AppKit');

function sleep(ms) {
  var start = new Date();
  while (new Date() - start < ms) {}
}

function zoneRect(zone, ox, oy, sw, sh) {
  var zones = {
    'full':                  [0,    0,    1,    1   ],
    'left-half':             [0,    0,    0.5,  1   ],
    'right-half':            [0.5,  0,    0.5,  1   ],
    'top-half':              [0,    0,    1,    0.5 ],
    'bottom-half':           [0,    0.5,  1,    0.5 ],
    'top-left-quarter':      [0,    0,    0.5,  0.5 ],
    'top-right-quarter':     [0.5,  0,    0.5,  0.5 ],
    'bottom-left-quarter':   [0,    0.5,  0.5,  0.5 ],
    'bottom-right-quarter':  [0.5,  0.5,  0.5,  0.5 ],
    'center-large':          [0.1,  0.1,  0.8,  0.8 ],
    'center-small':          [0.2,  0.2,  0.6,  0.6 ],
  };
  var z = zones[zone];
  if (!z) throw new Error('Unknown zone: ' + zone);
  return {
    x: Math.round(ox + z[0] * sw),
    y: Math.round(oy + z[1] * sh),
    w: Math.round(z[2] * sw),
    h: Math.round(z[3] * sh),
  };
}

function monitorBounds(monitorIdx) {
  var screens = $.NSScreen.screens;
  var idx = (monitorIdx < screens.count) ? monitorIdx : 0;
  var primaryH = $.NSScreen.screens.objectAtIndex(0).frame.size.height;
  var frame = $.NSScreen.screens.objectAtIndex(idx).frame;
  return {
    ox: Math.round(frame.origin.x),
    oy: Math.round(primaryH - frame.origin.y - frame.size.height),
    sw: Math.round(frame.size.width),
    sh: Math.round(frame.size.height),
  };
}

function waitForWindow(appName, timeoutMs) {
  var se = Application('System Events');
  var waited = 0;
  while (waited < timeoutMs) {
    sleep(200);
    waited += 200;
    try {
      if (se.processes.byName(appName).windows.length > 0) return true;
    } catch(e) {}
  }
  return false;
}

function positionApp(appName, zone, monitorIdx, url) {
  var app = Application(appName);
  if (url) {
    app.activate();
    app.openLocation(url);
  } else {
    app.activate();
  }
  waitForWindow(appName, 3000);
  var mb = monitorBounds(monitorIdx);
  var r  = zoneRect(zone, mb.ox, mb.oy, mb.sw, mb.sh);
  var se = Application('System Events');
  try {
    var wins = se.processes.byName(appName).windows;
    if (wins.length > 0) {
      wins[0].position = [r.x, r.y];
      wins[0].size     = [r.w, r.h];
    }
  } catch(e) {}
}

var configPath = $.NSProcessInfo.processInfo.environment.objectForKey('WS_CONFIG').js;
var raw = $.NSString.stringWithContentsOfFileEncodingError(configPath, $.NSUTF8StringEncoding, null).js;
var cfg = JSON.parse(raw);
var apps = cfg.apps || [];
for (var i = 0; i < apps.length; i++) {
  var e = apps[i];
  positionApp(e.app, e.zone, (e.monitor || 1) - 1, e.url || '');
}
'done';
JSEOF

  echo "✅  Done."
}

# ── main ──────────────────────────────────────────────────────────────────────

mkdir -p "$WORKSPACES_DIR"

case "${1:-}" in
  help|--help|-h)  usage ;;
  list)            cmd_list ;;
  edit)            [[ -n "${2:-}" ]] || die "Usage: workspace edit <name>"; cmd_edit "$2" ;;
  shortcuts)       cmd_shortcuts ;;
  schedule)        [[ -n "${2:-}" && -n "${3:-}" ]] || die "Usage: workspace schedule <name> <time>"; cmd_schedule "$2" "$3" ;;
  unschedule)      [[ -n "${2:-}" ]] || die "Usage: workspace unschedule <name>"; cmd_unschedule "$2" ;;
  schedules)       cmd_schedules ;;
  "")              usage ;;
  *)               cmd_launch "$1" ;;
esac
